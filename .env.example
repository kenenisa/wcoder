# Telegram
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Security
ENCRYPTION_KEY=32-byte-hex-key-for-aes-256-gcm

# Paths
DATA_DIR=./data
